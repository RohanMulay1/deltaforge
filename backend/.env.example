# DeltaForge environment configuration (copy to .env and fill in).
# .env is git-ignored. NEVER commit real secrets. (ARCHITECTURE.md §11.3)

# ── Required secrets (NO defaults — the backend fails fast at boot if absent) ──
# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Postgres DSN (hosted, e.g. Supabase). SUBSTITUTE THE REAL DATABASE PASSWORD.
# Accepts postgres:// , postgresql:// , postgresql+asyncpg:// , or
# postgresql+psycopg:// — the app normalizes to asyncpg, Alembic to psycopg.
# Example (Supabase): postgresql://postgres:YOUR_REAL_PASSWORD@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_REAL_PASSWORD@host:5432/postgres

# ── Local Wolfram Engine kernel (NO secret — it is a local install) ───────────
# DeltaForge drives a LOCAL Wolfram Engine 14.3 kernel via wolframclient. There
# is NO Wolfram Cloud and NO Secured Authentication Key. Point this at the
# installed WolframKernel.exe; a missing/unstartable kernel degrades gracefully
# to the labeled numeric_fallback (it never fails boot).
WOLFRAM_KERNEL_PATH=C:\Program Files\Wolfram Research\Wolfram Engine\14.3\WolframKernel.exe

# ── CORS allowlist (comma-separated; NEVER "*") ───────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000

# ── Market data ───────────────────────────────────────────────────────────────
# Provider selector consumed by the provider factory (default: yfinance).
MARKET_DATA_PROVIDER=yfinance

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL) ───────────────────────────
LOG_LEVEL=INFO

# ── Risk model defaults (optional overrides) ──────────────────────────────────
# US 3-month T-bill rate used as the risk-free rate in Black-Scholes math.
RISK_FREE_RATE=0.053
# Target portfolio delta for delta-neutral hedging (0.0 = fully neutral).
DELTA_TARGET=0.0
